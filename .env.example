# JARVIS Pro Configuration
# Copy this to .env and fill in your API keys

# AI Models
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Search
SEARCH_API_KEY=your_serpapi_key_here

# Voice
VOICE_NAME=en-US-GuyNeural
WAKE_WORD=jarvis
ENABLE_WAKE_WORD=true
MIC_DEVICE_INDEX=0

# Assistant
ASSISTANT_NAME=Jarvis
USER_NAME=User

# Memory
MEMORY_MAX_ITEMS=500
MEMORY_TTL_DAYS=90
DATABASE_PATH=./data/jarvis.db

# Features
AUTO_WEB_SEARCH_ENABLE=true
DEBUG_MODE=false

# Security
COMMAND_DENYLIST=rm,format,shutdown,reboot,del,wipe,sudo
COMMAND_ALLOWLIST=
