# JARVIS Pro v4.0 Configuration

# AI Providers
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
SEARCH_API_KEY=your_serpapi_key_here

# Ollama (Local AI)
ENABLE_OLLAMA=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# Voice Configuration
VOICE_NAME=en-US-GuyNeural
WAKE_WORD=jarvis
ENABLE_WAKE_WORD=true
MIC_DEVICE_INDEX=0

# Memory and Database
DATABASE_PATH=./data/jarvis.db
MEMORY_MAX_ITEMS=500
MEMORY_TTL_DAYS=90

# Assistant Settings
ASSISTANT_NAME=Jarvis
USER_NAME=User
ASSISTANT_VERSION=4.0.0

# Features
AUTO_WEB_SEARCH_ENABLE=true
ENABLE_CODING_ASSISTANT=true
ENABLE_WEBSITE_GENERATOR=true
ENABLE_APP_GENERATOR=true
ENABLE_GIT_INTEGRATION=true

# Debug
DEBUG_MODE=false
